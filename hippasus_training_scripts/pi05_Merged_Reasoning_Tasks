#!/bin/bash
set -euo pipefail

export PYTHONUNBUFFERED=1
export CUDA_VISIBLE_DEVICES=2

TOTAL_FRAMES=226574
BATCH_SIZE=32
EPOCHS=1
STEPS=$(( EPOCHS * ( (TOTAL_FRAMES + BATCH_SIZE - 1) / BATCH_SIZE ) ))
SAVE_FREQ="${STEPS}"
echo "Training for ${EPOCHS} epoch(s): ${TOTAL_FRAMES} frames, batch ${BATCH_SIZE}, steps ${STEPS}"

RUN_NAME=pi05_Merged_Reasoning_Tasks
OUTPUT_DIR=/vol/dissolve/justin/outputs/${RUN_NAME}

JOB_TMP="/vol/dissolve/justin/tmp/${USER}_${RUN_NAME}_tmp"
WANDB_ROOT="/vol/dissolve/justin/wandb_cache/${RUN_NAME}"

mkdir -p "${JOB_TMP}" "${WANDB_ROOT}/data" "${WANDB_ROOT}/cache" "${WANDB_ROOT}/artifacts"

export TMPDIR="${JOB_TMP}"
export TEMP="${JOB_TMP}"
export TMP="${JOB_TMP}"

export WANDB_DATA_DIR="${WANDB_ROOT}/data"
export WANDB_CACHE_DIR="${WANDB_ROOT}/cache"
export WANDB_ARTIFACT_DIR="${WANDB_ROOT}/artifacts"

cleanup() {
  rm -rf "${JOB_TMP}" || true
}
trap cleanup EXIT

export PATH="/vol/dissolve/justin/miniforge3/bin:$PATH"
source /vol/dissolve/justin/miniforge3/etc/profile.d/conda.sh
conda activate lerobot_pi05

export HF_HOME=/vol/dissolve/justin/hf_cache
export HF_HUB_CACHE="${HF_HOME}/hub"
export HF_DATASETS_CACHE="${HF_HOME}/datasets"
export TRANSFORMERS_CACHE="${HF_HOME}/hub"
export HF_TOKEN="$(cat "${HF_HOME}/token")"

lerobot-train \
  --dataset.repo_id=justintiensmith/Merged_Reasoning_Tasks \
  --policy.type=pi05 \
  --output_dir="${OUTPUT_DIR}" \
  --job_name="${RUN_NAME}" \
  --policy.pretrained_path=lerobot/pi05_base \
  --policy.dtype=bfloat16 \
  --policy.gradient_checkpointing=true \
  --policy.freeze_vision_encoder=false \
  --policy.train_expert_only=false \
  --steps="${STEPS}" \
  --wandb.enable=true \
  --wandb.disable_artifact=true \
  --batch_size="${BATCH_SIZE}" \
  --num_workers=8 \
  --save_freq="${SAVE_FREQ}" \
  --policy.device=cuda \
  --policy.repo_id=justintiensmith/pi05_SP_Counting \
  --policy.push_to_hub=true \
  --policy.compile_model=false \
  --policy.input_features='{"observation.state": {"type": "STATE", "shape": [6]}, "observation.images.wrist": {"type": "VISUAL", "shape": [3, 480, 640]}, "observation.images.middle": {"type": "VISUAL", "shape": [3, 480, 640]}, "observation.images.above": {"type": "VISUAL", "shape": [3, 480, 640]}}' \
  --policy.output_features='{"action": {"type": "ACTION", "shape": [6]}}' \
  --policy.normalization_mapping='{"ACTION": "QUANTILES", "STATE": "QUANTILES", "VISUAL": "IDENTITY"}'
