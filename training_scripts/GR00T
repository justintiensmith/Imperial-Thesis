#!/bin/bash
#SBATCH --partition=a100
#SBATCH --gres=gpu:1
#SBATCH --mem=64G
#SBATCH --cpus-per-task=4
#SBATCH --time=24:00:00
#SBATCH --output=gr00t_train_%j.out

echo "Job ID: $SLURM_JOB_ID"
echo "Running on node: $(hostname)"
echo "Allocated CPUs: $SLURM_CPUS_ON_NODE"
echo "Allocated Memory: $SLURM_MEM_PER_NODE"
echo "Allocated GPU(s):"
nvidia-smi
echo "Free RAM:"
free -h
echo "Disk space in /tmp:"
df -h /tmp
echo "-------------------------"
export PYTHONUNBUFFERED=1
export CUDA_VISIBLE_DEVICES=0

# Activate virtual environment
export PATH="/vol/dissolve/justin/miniforge3/bin:$PATH"
source /vol/dissolve/justin/miniforge3/etc/profile.d/conda.sh
conda activate lerobot

# Temporary cache folder on the compute node's local SSD
mkdir -p /tmp/jzt25_hf_cache

# Routing Hugging Face to use fast local drive instead of the network drive
export HF_HOME=/tmp/jzt25_hf_cache
export TRANSFORMERS_CACHE=/tmp/jzt25_hf_cache
export HF_DATASETS_CACHE=/tmp/jzt25_hf_cache

export HF_TOKEN=$"HF_TOKEN"

# Using a multi-GPU setup
accelerate launch \
  --multi_gpu \
  --num_processes=1 \
  $(which lerobot-train) \
  --output_dir=$OUTPUT_DIR \
  --save_checkpoint=true \
  --batch_size=16 \
  --steps=10000 \
  --save_freq=1000 \
  --log_freq=100 \
  --policy.push_to_hub=true \
  --policy.type=groot \
  --policy.repo_id=justintiensmith/groot_apple_policy \
  --policy.tune_diffusion_model=false \
  --dataset.repo_id=mattpidden/smol-vla-test-dataset \
  --wandb.enable=true \
  --wandb.disable_artifact=true \
  --job_name=groot_training \
  --rename_map='{"observation.images.claw":"observation.images.camera1","observation.images.world":"observation.images.camera2"}'
